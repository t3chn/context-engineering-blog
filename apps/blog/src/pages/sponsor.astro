---
import BaseLayout from "@/layouts/BaseLayout.astro";

const telegramUrl = "https://t.me/ctxtdev";
---

<BaseLayout title="Sponsor ctxt.dev" lang="en">
  <section aria-label="Sponsor hero" class="mb-12">
    <p class="mb-2 font-mono text-sm uppercase tracking-widest text-[var(--color-accent)]">
      Sponsorships
    </p>
    <h1 class="text-4xl font-bold tracking-tight text-[var(--color-text)] sm:text-5xl">
      Sponsor ctxt.dev
    </h1>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-[var(--color-text-secondary)]">
      ctxt.dev is a niche publication about AI agents, context engineering, and toolchains. The site
      reaches 5k+ monthly readers and 100+ daily readers in an engineering-heavy audience.
    </p>
  </section>

  <section class="grid gap-6 md:grid-cols-2">
    <article
      class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] p-6"
    >
      <h2 class="text-xl font-semibold text-[var(--color-text)]">What fits</h2>
      <ul class="mt-4 space-y-3 text-[var(--color-text-secondary)]">
        <li>AI agent infrastructure and developer tools</li>
        <li>Observability, security, evals, and deployment tooling</li>
        <li>APIs, data products, and platforms relevant to builders</li>
      </ul>
    </article>

    <article
      class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] p-6"
    >
      <h2 class="text-xl font-semibold text-[var(--color-text)]">Available formats</h2>
      <ul class="mt-4 space-y-3 text-[var(--color-text-secondary)]">
        <li>Sponsor mention on the site</li>
        <li>Telegram channel mention when the fit is strong</li>
        <li>Custom package for launches, research, or niche builder audiences</li>
      </ul>
    </article>
  </section>

  <section
    class="mt-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] p-6"
  >
    <h2 class="text-xl font-semibold text-[var(--color-text)]">Get in touch</h2>
    <p class="mt-3 max-w-2xl text-[var(--color-text-secondary)]">
      If you have a sponsor idea that matches the audience, message me in Telegram with a short
      brief, target audience, and what you want to promote.
    </p>
    <a
      href={telegramUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-6 inline-flex items-center gap-2 rounded-md bg-[var(--color-accent)] px-6 py-3 font-mono text-sm font-medium text-white transition-opacity hover:opacity-90"
    >
      Contact via Telegram
    </a>
  </section>
</BaseLayout>
